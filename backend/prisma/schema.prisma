generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id        Int       @id @default(autoincrement())
  name      String
  contact   String
  email     String    @unique
  phone     String
  birthdate DateTime?
  status    String    @default("Activo")
  events    Event[]
  createdAt DateTime  @default(now())
}

model Event {
  id        Int      @id @default(autoincrement())
  name      String
  date      DateTime
  venue     String
  type      String
  status    String   @default("Propuesta")
  guests    Int
  budget    Float
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  Int
  quotes    Quote[]
  createdAt DateTime @default(now())
}

model Quote {
  id        Int         @id @default(autoincrement())
  kind      String      @default("General")   // "General" | "Catering"
  date      DateTime    @default(now())
  status    String      @default("Pendiente")
  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   Int
  // Campos exclusivos de Catering (null en cotizaciones Generales)
  menu      String?
  covers    Int?
  pricePerCover Float?
  // Ítems: servicios generales O extras de catering (barra, torta, etc.)
  items     QuoteItem[]
  createdAt DateTime    @default(now())
}

model QuoteItem {
  id          Int    @id @default(autoincrement())
  description String
  quantity    Int
  unitPrice   Float
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     Int
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  category  String
  contact   String
  phone     String
  email     String   @unique
  rating    Int      @default(3)
  status    String   @default("Activo")
  createdAt DateTime @default(now())
}
