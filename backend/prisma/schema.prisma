generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Client {
  id        Int       @id @default(autoincrement())
  name      String
  contact   String
  email     String    @unique
  phone     String
  birthdate DateTime?
  status    String    @default("Activo")
  events    Event[]
  createdAt DateTime  @default(now())
}

model Event {
  id               Int               @id @default(autoincrement())
  name             String
  date             DateTime
  venue            String
  type             String
  status           String            @default("Propuesta")
  guests           Int
  budget           Float
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId         Int
  quotes           Quote[]
  payments         Payment[]
  supplierPayments SupplierPayment[]
  createdAt        DateTime          @default(now())
  checklist ChecklistItem[]
  files EventFile[]
}

model Quote {
  id            Int         @id @default(autoincrement())
  kind          String      @default("General")
  date          DateTime    @default(now())
  status        String      @default("Pendiente")
  event         Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId       Int
  menu          String?
  covers        Int?
  pricePerCover Float?
  items         QuoteItem[]
  createdAt     DateTime    @default(now())
}

model QuoteItem {
  id          Int    @id @default(autoincrement())
  description String
  quantity    Int
  unitPrice   Float
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     Int
}

model Payment {
  id        Int      @id @default(autoincrement())
  amount    Float
  date      DateTime @default(now())
  note      String?
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   Int
  createdAt DateTime @default(now())
}

model SupplierPayment {
  id         Int      @id @default(autoincrement())
  amount     Float
  date       DateTime @default(now())
  note       String?
  method     String   @default("Efectivo")
  status     String   @default("Pendiente")
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierId Int
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId    Int
  createdAt  DateTime @default(now())
}

model Supplier {
  id               Int               @id @default(autoincrement())
  name             String
  category         String
  contact          String
  phone            String
  email            String            @unique
  rating           Int               @default(3)
  status           String            @default("Activo")
  supplierPayments SupplierPayment[]
  createdAt        DateTime          @default(now())
}

model ChecklistItem {
  id        Int      @id @default(autoincrement())
  title     String
  done      Boolean  @default(false)
  order     Int      @default(0)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   Int
  createdAt DateTime @default(now())
}

model EventFile {
  id           Int      @id @default(autoincrement())
  name         String
  url          String
  publicId     String
  resourceType String   @default("raw")
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId      Int
  createdAt    DateTime @default(now())
}